# Stripe API keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...

# After creating an endpoint in Stripe Dashboard -> Developers -> Webhooks, or via:
#   stripe listen --forward-to localhost:8000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Must match the URL where the React app runs (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Durable webhook idempotency store
WEBHOOK_EVENT_DB=webhook_events.db
WEBHOOK_EVENT_TTL_SECONDS=2592000
